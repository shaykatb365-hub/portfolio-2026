---
layout: base.njk
title: "Work"
description: "Selected projects across brand identity, no-code web, and factory systems design."
---

<!-- ── Page Header ────────────────────────────────────────────────────────── -->
<section style="border-bottom: 1px solid var(--border); background: var(--deep); padding: 5rem 2rem 4rem; position: relative; overflow: hidden;">
  <!-- Background glow -->
  <div aria-hidden="true" style="
    position: absolute; bottom: -20%; right: 5%;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(255,77,28,0.07) 0%, transparent 70%);
    pointer-events: none;
  "></div>

  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="fu" style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 2rem; margin-bottom: 3rem;">
      <h1 class="display" style="font-size: clamp(3.5rem, 8vw, 7rem);">
        Selected<br /><em>Work.</em>
      </h1>
      <p style="color: var(--sub); max-width: 30ch; line-height: 1.8; font-size: 0.95rem; padding-bottom: 0.5rem;">
        Three disciplines. One approach — every decision earns its place.
      </p>
    </div>

    <!-- Category jump nav -->
    <nav class="fu fu1" style="display: flex; gap: 0; border-top: 1px solid var(--border);">
      <a href="#logo-graphic-design" style="
        font-family: var(--sans); font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--sub); padding: 1rem 1.5rem 1rem 0; margin-right: 1.5rem;
        border-top: 2px solid transparent; transition: color 0.2s, border-color 0.2s;
      " onmouseover="this.style.color='var(--bright)';this.style.borderColor='var(--fire)'"
         onmouseout="this.style.color='var(--sub)';this.style.borderColor='transparent'">
        01 — Logo &amp; Graphic Design
      </a>
      <a href="#no-code-web" style="
        font-family: var(--sans); font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--sub); padding: 1rem 1.5rem 1rem 0; margin-right: 1.5rem;
        border-top: 2px solid transparent; transition: color 0.2s, border-color 0.2s;
      " onmouseover="this.style.color='var(--bright)';this.style.borderColor='var(--fire)'"
         onmouseout="this.style.color='var(--sub)';this.style.borderColor='transparent'">
        02 — No-Code Web
      </a>
      <a href="#factory-project" style="
        font-family: var(--sans); font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--sub); padding: 1rem 0;
        border-top: 2px solid transparent; transition: color 0.2s, border-color 0.2s;
      " onmouseover="this.style.color='var(--bright)';this.style.borderColor='var(--fire)'"
         onmouseout="this.style.color='var(--sub)';this.style.borderColor='transparent'">
        03 — Factory Project
      </a>
    </nav>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- 01. Logo / Graphic Design                                              -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section id="logo-graphic-design" style="max-width: 1200px; margin: 0 auto; padding: 5rem 2rem 4rem; border-bottom: 1px solid var(--border);">

  <div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem;">
    <div style="display: flex; align-items: flex-end; gap: 1.5rem;">
      <span style="font-family: var(--serif); font-style: italic; font-size: 5rem; font-weight: 900; color: var(--border2); line-height: 1; user-select: none;">01</span>
      <div>
        <p class="label" style="margin-bottom: 0.4rem;">Category</p>
        <h2 class="display" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Logo &amp; Graphic Design</h2>
      </div>
    </div>
    <p style="color: var(--sub); max-width: 28ch; line-height: 1.75; font-size: 0.85rem; text-align: right;">
      Brand marks &amp; visual identities built for clarity and longevity.
    </p>
  </div>

  <!-- Logo grid -->
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 2px; background: var(--border);">
    {% for project in collections.logoProjects %}
    <a href="/work/logo-graphic-design/{{ project.data.slug }}/" class="logo-card" title="{{ project.data.title }}">
      {% if project.data.thumbnail %}
      <img src="{{ project.data.thumbnail }}" alt="{{ project.data.title }}" loading="lazy" />
      {% else %}
      <span class="label" style="text-align: center;">{{ project.data.title }}</span>
      {% endif %}
      <span class="logo-card-arrow">View →</span>
    </a>
    {% else %}
    <div class="logo-card" style="grid-column: 1 / -1; padding: 3rem; justify-content: flex-start; background: var(--deep);">
      <span class="label">No projects yet — <a href="/admin/" style="color: var(--fire); text-decoration: underline;">add via CMS</a></span>
    </div>
    {% endfor %}
  </div>

  <!-- Name strip under grid -->
  {% if collections.logoProjects.length %}
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 2px; background: var(--border); margin-top: 2px;">
    {% for project in collections.logoProjects %}
    <a href="/work/logo-graphic-design/{{ project.data.slug }}/" style="
      background: var(--deep); padding: 0.6rem 0.85rem;
      font-size: 0.65rem; font-weight: 600; letter-spacing: 0.06em;
      color: var(--muted); display: block;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      transition: color 0.2s;
    " onmouseover="this.style.color='var(--sub)'" onmouseout="this.style.color='var(--muted)'">
      {{ project.data.title }}{% if project.data.client %} — {{ project.data.client }}{% endif %}
    </a>
    {% endfor %}
  </div>
  {% endif %}
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- 02. No-Code Web                                                        -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section id="no-code-web" style="max-width: 1200px; margin: 0 auto; padding: 5rem 2rem 4rem; border-bottom: 1px solid var(--border);">

  <div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem;">
    <div style="display: flex; align-items: flex-end; gap: 1.5rem;">
      <span style="font-family: var(--serif); font-style: italic; font-size: 5rem; font-weight: 900; color: var(--border2); line-height: 1; user-select: none;">02</span>
      <div>
        <p class="label" style="margin-bottom: 0.4rem;">Category</p>
        <h2 class="display" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">No-Code Web</h2>
      </div>
    </div>
    <p style="color: var(--sub); max-width: 28ch; line-height: 1.75; font-size: 0.85rem; text-align: right;">
      High-performance sites shipped without writing a line of code.
    </p>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2px; background: var(--border);">
    {% for project in collections.noCodeProjects %}
    <a href="/work/no-code-web/{{ project.data.slug }}/" class="work-card">
      <div class="work-card-thumb-wrap">
        {% if project.data.thumbnail %}
        <img src="{{ project.data.thumbnail }}" alt="{{ project.data.title }}" class="thumb" loading="lazy" />
        {% else %}
        <div style="height:260px; background: var(--lifted); display:flex; align-items:center; justify-content:center;">
          <span class="label">{{ project.data.title }}</span>
        </div>
        {% endif %}
      </div>
      <div style="padding: 1.5rem 1.5rem 1.75rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 0.75rem;">
          {% if project.data.client %}<span class="badge">{{ project.data.client }}</span>{% endif %}
          {% if project.data.year %}<span class="label">{{ project.data.year }}</span>{% endif %}
        </div>
        <h3 class="display" style="font-size: 1.5rem; margin-bottom: 0.5rem;">{{ project.data.title }}</h3>
        <p style="color: var(--muted); font-size: 0.8rem; line-height: 1.6; margin: 0;">{{ project.data.description | truncate(90) }}</p>
      </div>
    </a>
    {% else %}
    <div class="work-card" style="padding: 3rem; background: var(--deep);">
      <span class="label">No projects yet — <a href="/admin/" style="color: var(--fire); text-decoration: underline;">add via CMS</a></span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- 03. Factory Project                                                    -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section id="factory-project" style="max-width: 1200px; margin: 0 auto; padding: 5rem 2rem;">

  <div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem;">
    <div style="display: flex; align-items: flex-end; gap: 1.5rem;">
      <span style="font-family: var(--serif); font-style: italic; font-size: 5rem; font-weight: 900; color: var(--border2); line-height: 1; user-select: none;">03</span>
      <div>
        <p class="label" style="margin-bottom: 0.4rem;">Category</p>
        <h2 class="display" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Factory Project</h2>
      </div>
    </div>
    <p style="color: var(--sub); max-width: 28ch; line-height: 1.75; font-size: 0.85rem; text-align: right;">
      Industrial &amp; systems design — where hard constraints create clarity.
    </p>
  </div>

  <!-- Editorial numbered list -->
  <div>
    {% for project in collections.factoryProjects %}
    <a href="/work/factory-project/{{ project.data.slug }}/" class="list-row">
      <span style="font-family: var(--serif); font-style: italic; font-size: 1.5rem; font-weight: 900; color: var(--fire); line-height: 1;">
        {{ "%02d" | format(loop.index) }}
      </span>
      <div>
        <h3 class="display" style="font-size: 1.6rem; margin-bottom: 0.35rem;">{{ project.data.title }}</h3>
        <p style="color: var(--muted); font-size: 0.8rem; margin: 0; line-height: 1.6;">{{ project.data.description | truncate(90) }}</p>
      </div>
      <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; min-width: fit-content;">
        {% if project.data.client %}<span class="badge">{{ project.data.client }}</span>{% endif %}
        {% if project.data.year %}<span class="label">{{ project.data.year }}</span>{% endif %}
        <span style="font-size: 0.7rem; color: var(--fire); margin-top: 0.25rem;">View →</span>
      </div>
    </a>
    {% else %}
    <div class="list-row" style="cursor: default; grid-template-columns: 1fr;">
      <span class="label">No projects yet — <a href="/admin/" style="color: var(--fire); text-decoration: underline;">add via CMS</a></span>
    </div>
    {% endfor %}
  </div>
</section>
