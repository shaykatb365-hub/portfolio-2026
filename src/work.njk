---
layout: base.njk
title: "Work"
description: "Selected projects across brand identity, no-code web, and factory systems design."
---

<!-- ── Page header ─────────────────────────────────────────────────────────── -->
<section class="max-w-6xl mx-auto px-6 pt-20 pb-16" style="border-bottom: 1px solid var(--rule);">
  <div class="fade-up" style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 2rem;">
    <h1 class="display" style="font-size: clamp(3rem, 7vw, 6rem); line-height: 1; max-width: 12ch;">
      Selected<br /><em>Work.</em>
    </h1>
    <p style="color: var(--mid); max-width: 32ch; line-height: 1.8; margin-bottom: 0.25rem;" class="fade-up fade-up-1">
      Three disciplines, one approach — make every decision count.
    </p>
  </div>

  <!-- Category jump links -->
  <nav class="fade-up fade-up-2" style="margin-top: 2.5rem; display: flex; gap: 1.5rem; flex-wrap: wrap;">
    <a href="#logo-graphic-design" class="nav-link">Logo &amp; Graphic Design</a>
    <a href="#no-code-web" class="nav-link">No-Code Web</a>
    <a href="#factory-project" class="nav-link">Factory Project</a>
  </nav>
</section>

<!-- ════════════════════════════════════════════════════════════════════════ -->
<!-- ── 1. Logo / Graphic Design ─────────────────────────────────────────── -->
<!-- ════════════════════════════════════════════════════════════════════════ -->
<section id="logo-graphic-design" class="max-w-6xl mx-auto px-6 pt-16 pb-16" style="border-bottom: 1px solid var(--rule);">

  <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
    <div>
      <p class="section-label" style="margin-bottom: 0.4rem;">01</p>
      <h2 class="display" style="font-size: clamp(1.8rem, 4vw, 3rem); margin: 0;">Logo &amp; Graphic Design</h2>
    </div>
    <p style="color: var(--mid); max-width: 30ch; line-height: 1.7; text-align: right; font-size: 0.8rem;">
      Brand marks, visual identities, and<br />graphic systems built to last.
    </p>
  </div>

  <!-- Logo grid — click to open case study -->
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1px; background: var(--rule);">
    {% for project in collections.logoProjects %}
    <a
      href="/work/logo-graphic-design/{{ project.data.slug }}/"
      class="logo-card"
      style="background: var(--paper);"
      title="{{ project.data.title }}"
    >
      {% if project.data.thumbnail %}
      <img src="{{ project.data.thumbnail }}" alt="{{ project.data.title }}" loading="lazy" />
      {% else %}
      <span class="section-label" style="text-align:center;">{{ project.data.title }}</span>
      {% endif %}
    </a>
    {% else %}
    <div class="logo-card" style="background:#fff; grid-column: 1/-1; padding: 4rem; justify-content: flex-start;">
      <span class="section-label">No projects yet — add them via <a href="/admin/" style="text-decoration:underline;">CMS</a>.</span>
    </div>
    {% endfor %}
  </div>

  <!-- Project title strip (appears below grid) -->
  {% if collections.logoProjects.length %}
  <ul style="margin-top: 1px; background: var(--rule); display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1px; list-style: none; padding: 0;">
    {% for project in collections.logoProjects %}
    <li style="background: var(--paper); padding: 0.6rem 0.75rem;">
      <a href="/work/logo-graphic-design/{{ project.data.slug }}/" style="font-size: 0.7rem; letter-spacing: 0.05em; color: var(--mid); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        {{ project.data.title }}{% if project.data.client %} — {{ project.data.client }}{% endif %}
      </a>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
</section>

<!-- ════════════════════════════════════════════════════════════════════════ -->
<!-- ── 2. No-Code Web ────────────────────────────────────────────────────── -->
<!-- ════════════════════════════════════════════════════════════════════════ -->
<section id="no-code-web" class="max-w-6xl mx-auto px-6 pt-16 pb-16" style="border-bottom: 1px solid var(--rule);">

  <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
    <div>
      <p class="section-label" style="margin-bottom: 0.4rem;">02</p>
      <h2 class="display" style="font-size: clamp(1.8rem, 4vw, 3rem); margin: 0;">No-Code Web</h2>
    </div>
    <p style="color: var(--mid); max-width: 30ch; line-height: 1.7; text-align: right; font-size: 0.8rem;">
      High-performance sites and products<br />shipped without writing a line of code.
    </p>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--rule);">
    {% for project in collections.noCodeProjects %}
    <a href="/work/no-code-web/{{ project.data.slug }}/" class="work-card" style="background: var(--paper); display: block; text-decoration: none;">
      {% if project.data.thumbnail %}
      <img src="{{ project.data.thumbnail }}" alt="{{ project.data.title }}" loading="lazy" />
      {% else %}
      <div style="height:200px; background: #ece9e2; display:flex; align-items:center; justify-content:center;">
        <span class="section-label">{{ project.data.title }}</span>
      </div>
      {% endif %}
      <div style="padding: 1.25rem 1.5rem 1.5rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
          {% if project.data.client %}<span class="badge">{{ project.data.client }}</span>{% endif %}
          {% if project.data.year %}<span class="section-label">{{ project.data.year }}</span>{% endif %}
        </div>
        <h3 class="display" style="font-size: 1.4rem; margin: 0.25rem 0 0.5rem;">{{ project.data.title }}</h3>
        <p style="color: var(--mid); font-size: 0.78rem; line-height: 1.6; margin: 0;">{{ project.data.description | truncate(100) }}</p>
      </div>
    </a>
    {% else %}
    <div class="work-card" style="background:#fff; padding: 4rem; grid-column: 1/-1;">
      <span class="section-label">No projects yet — add them via <a href="/admin/" style="text-decoration:underline;">CMS</a>.</span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════════════ -->
<!-- ── 3. Factory Project ─────────────────────────────────────────────────── -->
<!-- ════════════════════════════════════════════════════════════════════════ -->
<section id="factory-project" class="max-w-6xl mx-auto px-6 pt-16 pb-16">

  <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
    <div>
      <p class="section-label" style="margin-bottom: 0.4rem;">03</p>
      <h2 class="display" style="font-size: clamp(1.8rem, 4vw, 3rem); margin: 0;">Factory Project</h2>
    </div>
    <p style="color: var(--mid); max-width: 30ch; line-height: 1.7; text-align: right; font-size: 0.8rem;">
      Industrial and systems design —<br />where constraints create clarity.
    </p>
  </div>

  <!-- Full-width editorial list layout for Factory -->
  <div style="display: flex; flex-direction: column;">
    {% for project in collections.factoryProjects %}
    <a
      href="/work/factory-project/{{ project.data.slug }}/"
      style="display: grid; grid-template-columns: auto 1fr auto; gap: 2rem; align-items: center; padding: 1.5rem 0; border-top: 1px solid var(--rule); text-decoration: none; transition: background 0.15s;"
      onmouseover="this.style.background='#fff'" onmouseout="this.style.background='transparent'"
    >
      <span class="section-label" style="min-width: 2.5rem;">{{ "%02d" | format(loop.index) }}</span>

      <div>
        <h3 class="display" style="font-size: 1.5rem; margin: 0 0 0.25rem;">{{ project.data.title }}</h3>
        <p style="color: var(--mid); font-size: 0.78rem; margin: 0;">{{ project.data.description | truncate(90) }}</p>
      </div>

      <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem;">
        {% if project.data.client %}<span class="badge">{{ project.data.client }}</span>{% endif %}
        {% if project.data.year %}<span class="section-label">{{ project.data.year }}</span>{% endif %}
      </div>
    </a>
    {% else %}
    <div style="padding: 3rem 0; border-top: 1px solid var(--rule);">
      <span class="section-label">No projects yet — add them via <a href="/admin/" style="text-decoration:underline;">CMS</a>.</span>
    </div>
    {% endfor %}
    <div style="border-top: 1px solid var(--rule);"></div>
  </div>
</section>
