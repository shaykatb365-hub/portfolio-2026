<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or site.description }}" />
    <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>

    <!-- Fonts: DM Serif Display (editorial) + DM Mono (utilitarian) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/assets/css/output.css" />

    <style>
      :root {
        --ink: #0e0e0e;
        --paper: #f5f3ee;
        --accent: #c8f135;   /* acid yellow — single pop of colour */
        --mid: #6b6b6b;
        --rule: #d4d0c8;
        --serif: "DM Serif Display", serif;
        --mono: "DM Mono", monospace;
      }

      * { box-sizing: border-box; }

      html { background: var(--paper); color: var(--ink); }

      body {
        font-family: var(--mono);
        font-size: 0.875rem;
        letter-spacing: 0.01em;
        line-height: 1.65;
        background: var(--paper);
        min-height: 100dvh;
      }

      /* ── Typography ─────────────────────────────────── */
      .display {
        font-family: var(--serif);
        line-height: 1;
        letter-spacing: -0.03em;
      }

      /* ── Links ──────────────────────────────────────── */
      a { color: inherit; text-decoration: none; }
      a:hover { color: var(--ink); }

      /* ── Nav underline ──────────────────────────────── */
      .nav-link {
        position: relative;
        font-family: var(--mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--mid);
        transition: color 0.2s;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        left: 0; bottom: -2px;
        width: 0; height: 1px;
        background: var(--ink);
        transition: width 0.25s ease;
      }
      .nav-link:hover, .nav-link[aria-current="page"] {
        color: var(--ink);
      }
      .nav-link:hover::after, .nav-link[aria-current="page"]::after {
        width: 100%;
      }

      /* ── Accent pill ────────────────────────────────── */
      .badge {
        display: inline-block;
        background: var(--accent);
        color: var(--ink);
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 2px 8px;
        border-radius: 2px;
      }

      /* ── Rule ───────────────────────────────────────── */
      .rule { border-color: var(--rule); }

      /* ── Logo grid card ─────────────────────────────── */
      .logo-card {
        aspect-ratio: 1;
        background: #fff;
        border: 1px solid var(--rule);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        transition: border-color 0.2s, transform 0.2s;
        cursor: pointer;
        overflow: hidden;
        position: relative;
      }
      .logo-card::after {
        content: "View →";
        font-family: var(--mono);
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        position: absolute;
        bottom: 10px;
        right: 12px;
        opacity: 0;
        transition: opacity 0.2s;
        color: var(--mid);
      }
      .logo-card:hover {
        border-color: var(--ink);
        transform: translateY(-2px);
      }
      .logo-card:hover::after { opacity: 1; }
      .logo-card img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.3s;
      }
      .logo-card:hover img { transform: scale(1.04); }

      /* ── Featured work card ─────────────────────────── */
      .work-card {
        border: 1px solid var(--rule);
        overflow: hidden;
        transition: border-color 0.2s;
      }
      .work-card:hover { border-color: var(--ink); }
      .work-card img {
        width: 100%;
        height: 240px;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
      }
      .work-card:hover img { transform: scale(1.03); }

      /* ── Section label ──────────────────────────────── */
      .section-label {
        font-family: var(--mono);
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--mid);
      }

      /* ── CTA button ─────────────────────────────────── */
      .btn {
        display: inline-block;
        font-family: var(--mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 10px 22px;
        border: 1px solid var(--ink);
        background: transparent;
        color: var(--ink);
        transition: background 0.2s, color 0.2s;
        cursor: pointer;
      }
      .btn:hover {
        background: var(--ink);
        color: var(--paper);
      }
      .btn-accent {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--ink);
      }
      .btn-accent:hover {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--paper);
      }

      /* ── Page fade in ───────────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up {
        animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      .fade-up-1 { animation-delay: 0.05s; }
      .fade-up-2 { animation-delay: 0.15s; }
      .fade-up-3 { animation-delay: 0.25s; }
      .fade-up-4 { animation-delay: 0.35s; }
    </style>
  </head>

  <body>
    <!-- ── Navigation ──────────────────────────────────────────────────── -->
    <header class="sticky top-0 z-50" style="background: var(--paper); border-bottom: 1px solid var(--rule);">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="display text-lg tracking-tight" style="font-size:1.1rem;">
          {{ site.name }}
        </a>
        <nav class="flex items-center gap-8">
          <a href="/" class="nav-link" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
          <a href="/work/" class="nav-link" {% if "/work" in page.url %}aria-current="page"{% endif %}>Work</a>
          <a href="/about/" class="nav-link" {% if "/about" in page.url %}aria-current="page"{% endif %}>About</a>
          <a href="/about/#contact" class="btn" style="padding: 6px 16px; font-size:0.7rem;">Let's talk</a>
        </nav>
      </div>
    </header>

    <!-- ── Page content ─────────────────────────────────────────────────── -->
    <main>
      {{ content | safe }}
    </main>

    <!-- ── Footer ───────────────────────────────────────────────────────── -->
    <footer style="border-top: 1px solid var(--rule); margin-top: 6rem; padding: 2rem 0;">
      <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
        <span class="section-label">© {{ site.name }} {{ "" | date("yyyy") }}</span>
        <div class="flex gap-6">
          {% if site.social.dribbble %}
          <a href="{{ site.social.dribbble }}" class="nav-link" target="_blank" rel="noopener">Dribbble</a>
          {% endif %}
          {% if site.social.linkedin %}
          <a href="{{ site.social.linkedin }}" class="nav-link" target="_blank" rel="noopener">LinkedIn</a>
          {% endif %}
          {% if site.social.twitter %}
          <a href="{{ site.social.twitter }}" class="nav-link" target="_blank" rel="noopener">Twitter</a>
          {% endif %}
        </div>
      </div>
    </footer>
  </body>
</html>
