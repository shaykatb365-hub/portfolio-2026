---
layout: base.njk
---

<!-- Hero -->
<section style="border-bottom: 1px solid var(--border); background: var(--deep);">
  <div style="max-width: 1200px; margin: 0 auto; padding: 5rem 2rem 4rem;">

    <!-- Breadcrumb -->
    <div class="label fu" style="display: flex; gap: 0.75rem; margin-bottom: 3rem;">
      <a href="/work/" style="color: var(--muted); transition: color 0.2s;" onmouseover="this.style.color='var(--bright)'" onmouseout="this.style.color='var(--muted)'">Work</a>
      <span style="color: var(--border2);">/</span>
      <span style="color: var(--sub);">{{ title }}</span>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: end;">
      <div>
        {% if client %}
        <div class="badge fu" style="margin-bottom: 1.5rem;">{{ client }}</div>
        {% endif %}
        <h1 class="display fu fu1" style="font-size: clamp(3rem, 6vw, 5.5rem); margin-bottom: 1.5rem;">
          {{ title }}
        </h1>
        <p class="fu fu2" style="color: var(--sub); line-height: 1.8; max-width: 38ch;">
          {{ description }}
        </p>
      </div>

      <!-- Meta table -->
      <div class="fu fu3">
        <table style="width: 100%; border-collapse: collapse;">
          {% if client %}
          <tr style="border-top: 1px solid var(--border);">
            <td class="label" style="padding: 1rem 0; width: 40%;">Client</td>
            <td style="padding: 1rem 0; color: var(--bright); font-weight: 600;">{{ client }}</td>
          </tr>
          {% endif %}
          {% if year %}
          <tr style="border-top: 1px solid var(--border);">
            <td class="label" style="padding: 1rem 0;">Year</td>
            <td style="padding: 1rem 0; color: var(--bright); font-weight: 600;">{{ year }}</td>
          </tr>
          {% endif %}
          {% if services and services.length %}
          <tr style="border-top: 1px solid var(--border);">
            <td class="label" style="padding: 1rem 0; vertical-align: top;">Services</td>
            <td style="padding: 1rem 0; color: var(--bright); font-weight: 600; line-height: 1.8;">{{ services | join("<br/>") | safe }}</td>
          </tr>
          {% endif %}
          {% if url %}
          <tr style="border-top: 1px solid var(--border);">
            <td class="label" style="padding: 1rem 0;">Live</td>
            <td style="padding: 1rem 0;">
              <a href="{{ url }}" target="_blank" rel="noopener" style="color: var(--fire); font-weight: 600; font-size: 0.8rem; letter-spacing: 0.05em;">
                Visit site →
              </a>
            </td>
          </tr>
          {% endif %}
          <tr style="border-top: 1px solid var(--border);"><td colspan="2" style="padding: 0;"></td></tr>
        </table>
      </div>
    </div>
  </div>

  <!-- Hero visual -->
  {% if hero %}
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
    <img src="{{ hero }}" alt="{{ title }}" style="width: 100%; max-height: 580px; object-fit: cover; display: block; filter: brightness(0.9);" />
  </div>
  {% elif thumbnail %}
  <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; background: var(--surface); display: flex; justify-content: center; margin-bottom: 0;">
    <img src="{{ thumbnail }}" alt="{{ title }}" style="max-height: 280px; max-width: 380px; object-fit: contain; display: block;" />
  </div>
  {% endif %}
</section>

<!-- Case study body -->
<section style="max-width: 760px; margin: 0 auto; padding: 5rem 2rem;">
  <div class="prose-body">
    {{ content | safe }}
  </div>
</section>

<!-- Gallery -->
{% if gallery and gallery.length %}
<section style="border-top: 1px solid var(--border); padding: 4rem 0; background: var(--deep);">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
    <p class="label" style="margin-bottom: 2rem;">Project Gallery</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2px; background: var(--border);">
      {% for item in gallery %}
      <figure style="margin:0; background: var(--deep); overflow: hidden;">
        <img src="{{ item.image }}" alt="{{ item.caption or title }}" style="width:100%; height:280px; object-fit:cover; display:block; filter: brightness(0.85); transition: filter 0.3s;" onmouseover="this.style.filter='brightness(1)'" onmouseout="this.style.filter='brightness(0.85)'" />
        {% if item.caption %}
        <figcaption class="label" style="padding: 0.75rem 1rem; color: var(--muted);">{{ item.caption }}</figcaption>
        {% endif %}
      </figure>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Back -->
<div style="max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; border-top: 1px solid var(--border);">
  <a href="/work/" class="btn">← All Work</a>
</div>

<style>
  .prose-body h2 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 2.2rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--bright);
    margin: 3.5rem 0 1rem;
  }
  .prose-body h3 {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fire);
    margin: 2.5rem 0 0.75rem;
  }
  .prose-body p { margin-bottom: 1.4rem; color: var(--sub); line-height: 1.85; font-size: 1rem; }
  .prose-body ul, .prose-body ol { padding-left: 1.5rem; margin-bottom: 1.4rem; }
  .prose-body li { margin-bottom: 0.4rem; color: var(--sub); }
  .prose-body strong { color: var(--bright); font-weight: 600; }
  .prose-body blockquote {
    border-left: 3px solid var(--fire);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--surface);
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1.45;
    color: var(--bright);
  }
  .prose-body hr { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }
  .prose-body a { color: var(--fire); text-decoration: underline; text-underline-offset: 3px; }
  .prose-body img { width: 100%; height: auto; margin: 2rem 0; }
</style>
